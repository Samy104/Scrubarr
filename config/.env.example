# Required
PLEX_TOKEN=your_plex_token_here

# Defaults below work for a docker compose deployment alongside Plex on the same host
PLEX_BASE_URL=http://172.18.0.1:32400
DATABASE_URL=file:/db/scrubarr.db
LOG_LEVEL=INFO

# Only needed if you front Scrubarr with jwilder/nginx-proxy
VIRTUAL_HOST=scrubarr.example.com
LETSENCRYPT_HOST=scrubarr.example.com
LETSENCRYPT_EMAIL=you@example.com
