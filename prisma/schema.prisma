generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model IgnoredItem {
  id          Int      @id @default(autoincrement())
  ratingKey   String   @unique
  title       String?
  type        String?  // movie | show | episode
  ignoredAt   DateTime @default(now())
  reason      String?
}

model DeletionLog {
  id          Int      @id @default(autoincrement())
  ratingKey   String
  parentRatingKey String? // for episodes: the show's key
  title       String?
  showTitle   String?
  seasonEpisode String? // e.g. "S01E03"
  mediaId     String?
  filePath    String?
  sizeBytes   BigInt?
  resolution  String?
  videoCodec  String?
  qualityTags String?  // JSON-stringified list
  deletedAt   DateTime @default(now())
  status      String   // success | failed
  error       String?
  triggeredBy String?  // user | rule | manual | bulk

  @@index([ratingKey])
  @@index([deletedAt])
}

model Rule {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  scope       String   // movie | show | anime | all
  priority    Int      @default(100) // lower = applied first
  enabled     Boolean  @default(true)

  // Match criteria - all stored as JSON
  matchJson   String   // {titleRegex?, yearMin?, yearMax?, genres?: string[], collections?: string[], studios?: string[], libraries?: string[]}
  // Action - stored as JSON
  actionJson  String   // {kind: "prefer_resolution" | "prefer_largest" | "prefer_codec" | "ignore" | "mark_review", value?: string}

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  appliedCount Int     @default(0)
}

model ScanState {
  id              Int      @id @default(1)
  lastScanAt      DateTime?
  lastScanCount   Int      @default(0)
  lastScanError   String?
  lastScanDuration Int     @default(0) // seconds
}

/// Items the user has explicitly exempted from cleanup. An ignored item is
/// never a candidate even if eligibility rules match. Separate from IgnoredItem
/// (which guards the dedupe view) so the two flows don't bleed into each other.
model CleanupIgnoredItem {
  id          Int      @id @default(autoincrement())
  ratingKey   String   @unique
  scope       String   // movie | show
  title       String?
  sectionTitle String?
  reason      String?
  ignoredAt   DateTime @default(now())
}

/// Cleanup rules govern which movies / shows are considered candidates for
/// deletion based on watch history and ratings. Two kinds:
/// - 'exception'  : matching items are NEVER candidates (e.g. always keep Marvel)
/// - 'eligibility': matching items + condition match makes them a candidate
///                  (e.g. unwatched + rating < 5)
model CleanupRule {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?
  scope          String   // movie | show
  kind           String   // exception | eligibility
  priority       Int      @default(50) // lower = applied first; exceptions always win regardless
  enabled        Boolean  @default(true)

  /// Library-side filter: {titleRegex?, yearMin?, yearMax?, libraries?, genres?, collections?, studios?, contentRatings?}
  matchJson      String   @default("{}")
  /// Eligibility checks (ignored for exception rules):
  /// {viewCount?: {min?, max?}, daysSinceLastView?: {min?, max?}, neverViewed?: bool,
  ///  rating?: {min?, max?}, userRating?: {min?, max?}, audienceRating?: {min?, max?},
  ///  showCompletion?: {min?, max?}}  // viewedLeafCount / leafCount for shows
  conditionsJson String   @default("{}")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Per-series preference for the TV / Anime libraries.
/// When set, the scanner marks every duplicate episode of that show as either
/// autoClean (the preferred version exists and the others can be deleted) or
/// needsReview (no version matches the preference - fall back to manual review).
model SeriesPreference {
  id                  Int      @id @default(autoincrement())
  showRatingKey       String   @unique
  showTitle           String
  sectionTitle        String?  // "TV Shows" / "Anime"
  preferredResolution String?  // 2160p | 1080p | 720p | 480p
  preferredCodec      String?  // x265 / x264 / etc. substring match on videoCodec
  preferRemux         Boolean  @default(false) // also require REMUX in quality tags
  enabled             Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
